{
  "compileOnSave": true,
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "node16",
    "declaration": true,
    "strict": true,
    "lib": ["ES2022"],
    "module": "node16",
    "target": "ES2022",
    "rootDir": "./src",
    "outDir": "./lib",
    "sourceMap": true,
    "esModuleInterop": true,
    "typeRoots": ["node_modules/@types"],
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/__tests__/*"]
}
