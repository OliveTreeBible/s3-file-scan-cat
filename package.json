{
  "name": "s3-file-scan-cat",
  "version": "2.0.0",
  "description": "A utility to recursively scan a specified folder in S3 and concat JSON files within a single folder into a single gzip file.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OliveTreeBible/s3-file-scan-cat.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "aws",
    "s3"
  ],
  "author": "David Trotz",
  "license": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@smithy/node-http-handler": "^4.6.1",
    "ot-logger-deluxe": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smithy/util-stream": "^4.5.25",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
